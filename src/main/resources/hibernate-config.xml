<?xml version="1.0" encoding="utf-8"?>
<hibernate-configuration>
    <session-factory>
        <property name="hibernate.dialect">org.hibernate.dialect.PostgreSQL82Dialect</property>
        <property name="hibernate.connection.driver_class">org.postgresql.Driver</property>
        <property name="hibernate.connection.username">airq_user</property>
        <property name="hibernate.connection.password">12345</property>
        <property name="hibernate.connection.url">jdbc:postgresql://localhost:8081/AirQ</property>
        <property name="hbm2ddl.auto">update</property>
        <property name="show_sql">true</property>

        <!-- MAPPINGS -->
        <mapping class="dasturlash.uz.entity.Substance"/>
        <mapping class="dasturlash.uz.entity.Profile"/>
        <mapping class="dasturlash.uz.entity.JobPosition"/>
        <mapping class="dasturlash.uz.entity.Vocation"/>
        <mapping class="dasturlash.uz.entity.Sensor"/>
        <mapping class="dasturlash.uz.entity.Station"/>
        <mapping class="dasturlash.uz.entity.Pollutant"/>
        <mapping class="dasturlash.uz.entity.Measurement"/>

    </session-factory>

</hibernate-configuration>
